OPENAI_API_KEY=sk-...
SONIOX_API_KEY=...

# Feedback email (SMTP). Leave unset to disable the feedback feature.
# Example for Gmail: host smtp.gmail.com, port 587, an app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@example.com
SMTP_PASSWORD=your-app-password
# Optional; defaults to SMTP_USER.
SMTP_FROM=your-sender@example.com
